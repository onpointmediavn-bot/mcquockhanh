<!-- ==========================================
         SECTION 16 — GIẢI GOLF “VÒNG TAY NHÂN ÁI”
         ========================================== -->
    <section class="poster-container bg-navy" id="poster-golf">
      <div class="poster-bg opacity-25" style="background-image: url('assets/images/Golf/_MGL9352.jpg');"></div>
      <div class="poster-overlay-gradient"></div>

      <div class="poster-content text-center">
        <div class="max-w-4xl mx-auto space-y-6">
          <div class="flex justify-between items-center text-billing-credit">
            <div>MC QUỐC KHÁNH</div>
            <div class="text-burntOrange font-semibold">GIẢI GOLF TỪ THIỆN</div>
          </div>
          
          <h2 class="text-3xl md:text-5xl text-cinematic-title text-white tracking-wide glow-text-orange leading-tight uppercase">
            Giải Golf “Vòng Tay Nhân Ái”
          </h2>
          <p class="text-lg md:text-xl font-serif text-gray-300 max-w-2xl mx-auto italic">
            “Sự kiện đỉnh cao, mang đến trải nghiệm sống động và đầy cảm hứng cho khán giả.”
          </p>

          <!-- Event Gallery Grid (Editorial Layout for 4 images) -->
          <div class="space-y-4 mt-8 pt-6 border-t border-gray-800/60 text-left">
            <!-- Top Row: Main Showcase & Right Stack -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
              <!-- Big Showcase Image (Left, spans 8/12) -->
              <div class="md:col-span-8 relative aspect-[16/10] overflow-hidden rounded border border-gray-800/80 group transition-all duration-300 shadow-lg">
                <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('assets/images/Golf/_MGL9352.jpg');"></div>
                <div class="absolute bottom-4 left-4 bg-navy/80 backdrop-blur-md px-3 py-1.5 rounded border border-gray-800/60 text-[10px] tracking-widest text-amber-500 uppercase font-condensed">TIÊU ĐIỂM</div>
              </div>
              
              <!-- Stack of Two Right Images (Right, spans 4/12) -->
              <div class="md:col-span-4 flex flex-col justify-between gap-4">
                <div class="relative flex-1 aspect-[16/10] md:aspect-auto overflow-hidden rounded border border-gray-800/80 group transition-all duration-300 shadow-md">
                  <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('assets/images/Golf/481158877_1182955373274902_118307908177925426_n.jpg');"></div>
                </div>
                <div class="relative flex-1 aspect-[16/10] md:aspect-auto overflow-hidden rounded border border-gray-800/80 group transition-all duration-300 shadow-md">
                  <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('assets/images/Golf/481277035_1182955446608228_8635055377612117543_n.jpg');"></div>
                </div>
              </div>
            </div>

            <!-- Bottom Row: 1 Widescreen cinematic image -->
            <div class="relative aspect-[21/9] overflow-hidden rounded border border-gray-800/80 group transition-all duration-300 shadow-md">
              <div class="absolute inset-0 bg-cover bg-center group-hover:scale-105 transition-transform duration-700" style="background-image: url('assets/images/Golf/_MGL9349.jpg');"></div>
            </div>
          </div>
          
          <div class="text-billing-credit tracking-[0.4em] !text-[9px] mt-6 pt-4 border-t border-gray-800/30">
            DẪN DẮT SÂN GOLF • NĂNG LƯỢNG HÒA BÌNH • MC QUỐC KHÁNH
          </div>
        </div>
      </div>
    </section>
